# Code Review 技術債清理 — 完成報告

## 修正摘要

### 問題一（最高優先）：消除重複 A* 實作 ✅

**Before**: [ShortestPathPlanner](file:///d:/Full_end/C%23/ArtaleAI/Core/Domain/Navigation/ShortestPathPlanner.cs#11-45) 和 [NavigationGraph](file:///d:/Full_end/C%23/ArtaleAI/Core/Domain/Navigation/NavigationGraph.cs#13-256) 各自實作了一套 A*

| | `NavigationGraph.FindPath()` | `ShortestPathPlanner.PlanPath()` |
|---|---|---|
| 資料結構 | `SortedSet` + `inOpenSet` HashSet | `PriorityQueue` |
| 優先權更新 | ✅ 正確 remove → re-add | ❌ 重複入隊 |
| 結果 | **保留** | **已委派** |

**After**: `ShortestPathPlanner.PlanPath()` 現在只有一行：

```csharp
return graph.FindPath(startNodeId, goalNodeId);
```

刪除了 ~80 行重複且有 bug 的程式碼。

```diff:ShortestPathPlanner.cs
using System;
using System.Collections.Generic;
using System.Linq;
using ArtaleAI.Utils; // for logging

namespace ArtaleAI.Core.Domain.Navigation
{
    /// <summary>
    /// 最短路徑規劃器 (基於 A* 演算法)
    /// </summary>
    public class ShortestPathPlanner : IPathPlanner
    {
        public NavigationPath? PlanPath(NavigationGraph graph, System.Drawing.PointF startPos, System.Drawing.PointF goalPos)
        {
            // 1. 尋找最近的圖節點
            var startNode = graph.FindNearestNode(startPos, 100f); // 100px 內
            var goalNode = graph.FindNearestNode(goalPos, 100f);

            if (startNode == null)
            {
                Logger.Warning($"[PathPlanner] Cannot find node near start position {startPos}");
                return null;
            }
            if (goalNode == null)
            {
                Logger.Warning($"[PathPlanner] Cannot find node near goal position {goalPos}");
                return null;
            }

            // 2. 執行圖搜尋
            return PlanPath(graph, startNode.Id, goalNode.Id);
        }

        public NavigationPath? PlanPath(NavigationGraph graph, string startNodeId, string goalNodeId)
        {
            if (startNodeId == goalNodeId) return new NavigationPath(); // Already there

            // A* Algorithm
            var openSet = new PriorityQueue<string, float>();
            openSet.Enqueue(startNodeId, 0);

            var cameFrom = new Dictionary<string, NavigationEdge>();
            var gScore = new Dictionary<string, float>(); // Cost from start to current
            gScore[startNodeId] = 0;

            var fScore = new Dictionary<string, float>(); // Estimated total cost
            fScore[startNodeId] = Heuristic(graph, startNodeId, goalNodeId);

            var closedSet = new HashSet<string>();

            while (openSet.Count > 0)
            {
                var currentId = openSet.Dequeue();
                
                if (currentId == goalNodeId)
                {
                    return ReconstructPath(cameFrom, currentId);
                }

                closedSet.Add(currentId);

                // Expand neighbors
                foreach (var edge in graph.GetOutgoingEdges(currentId))
                {
                    var neighborId = edge.ToNodeId;
                    if (closedSet.Contains(neighborId)) continue;

                    float tentativeGScore = gScore[currentId] + edge.Cost;

                    if (!gScore.ContainsKey(neighborId) || tentativeGScore < gScore[neighborId])
                    {
                        // Found a better path
                        cameFrom[neighborId] = edge;
                        gScore[neighborId] = tentativeGScore;
                        float h = Heuristic(graph, neighborId, goalNodeId);
                        fScore[neighborId] = gScore[neighborId] + h;

                        // PriorityQueue doesn't support UpdatePriority easily in standard lib depending on version,
                        // simpler to just enqueue (duplicates handled by visited check logic implicitly or overhead)
                        // For simplicity in this PoC, we enqueue. 
                        openSet.Enqueue(neighborId, fScore[neighborId]);
                    }
                }
            }

            Logger.Warning($"[PathPlanner] No path found from {startNodeId} to {goalNodeId}");
            return null; // Path not found
        }

        private float Heuristic(NavigationGraph graph, string nodeId, string goalId)
        {
            // Euclidean distance as heuristic
            var node = graph.GetNode(nodeId);
            var goal = graph.GetNode(goalId);
            
            if (node == null || goal == null) return 0;

            float dx = node.Position.X - goal.Position.X;
            float dy = node.Position.Y - goal.Position.Y;
            return (float)Math.Sqrt(dx * dx + dy * dy);
        }

        private NavigationPath ReconstructPath(Dictionary<string, NavigationEdge> cameFrom, string currentId)
        {
            var pathEdges = new List<NavigationEdge>();
            while (cameFrom.ContainsKey(currentId))
            {
                var edge = cameFrom[currentId];
                pathEdges.Add(edge);
                currentId = edge.FromNodeId;
            }
            pathEdges.Reverse(); // Backtrack gives path in reverse
            return new NavigationPath(pathEdges);
        }
    }
}
===
using System;
using System.Collections.Generic;
using System.Linq;
using ArtaleAI.Utils; // for logging

namespace ArtaleAI.Core.Domain.Navigation
{
    /// <summary>
    /// 最短路徑規劃器 (基於 A* 演算法)
    /// </summary>
    public class ShortestPathPlanner : IPathPlanner
    {
        public NavigationPath? PlanPath(NavigationGraph graph, System.Drawing.PointF startPos, System.Drawing.PointF goalPos)
        {
            // 1. 尋找最近的圖節點
            var startNode = graph.FindNearestNode(startPos, 100f); // 100px 內
            var goalNode = graph.FindNearestNode(goalPos, 100f);

            if (startNode == null)
            {
                Logger.Warning($"[PathPlanner] Cannot find node near start position {startPos}");
                return null;
            }
            if (goalNode == null)
            {
                Logger.Warning($"[PathPlanner] Cannot find node near goal position {goalPos}");
                return null;
            }

            // 2. 執行圖搜尋
            return PlanPath(graph, startNode.Id, goalNode.Id);
        }

        /// <summary>
        /// 🧠 策略委派：統一使用 NavigationGraph.FindPath() 的正確 A* 實作
        /// 原先此處有獨立的 PriorityQueue 版 A*，但因 .NET PriorityQueue 不支援
        /// UpdatePriority，會導致重複入隊（效能 bug）。現已統一委派。
        /// </summary>
        public NavigationPath? PlanPath(NavigationGraph graph, string startNodeId, string goalNodeId)
        {
            // 直接委派給 NavigationGraph 內建的 SortedSet A*（有正確的優先權更新）
            return graph.FindPath(startNodeId, goalNodeId);
        }
    }
}
