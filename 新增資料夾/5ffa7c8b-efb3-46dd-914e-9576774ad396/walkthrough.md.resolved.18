### 問題三：標註 SmartRopeNavigator 為過時 ✅

在 Edge-Driven 架構下，[InjectRopeEdges()](file:///d:/Full_end/C%23/ArtaleAI/Core/PathPlanningTracker.cs#274-342) + A* 已完全取代 BFS 繩索搜尋。
加上 `[Obsolete]` 屬性，防止未來誤用。

```diff:SmartRopeNavigator.cs
using System;
using System.Collections.Generic;
using System.Linq;
using System.Drawing;
using ArtaleAI.Models.PathPlanning;
using ArtaleAI.Utils;
using SdPointF = System.Drawing.PointF;

namespace ArtaleAI.Services
{
    /// <summary>
    /// 智慧繩索導航器
    /// 使用圖搜尋算法 (BFS) 尋找跨樓層的繩索路徑
    /// </summary>
    public class SmartRopeNavigator
    {
        private class GraphNode
        {
            public SdPointF Position { get; set; }
            public RopeData? AssociatedRope { get; set; } // 如果是繩索端點，關聯的繩索
            public bool IsRopeTop { get; set; } // 是繩索頂端還是底端
            public GraphNode? Parent { get; set; } // 用於回溯路徑
            public RopeData? UsedRope { get; set; } // 到達此節點所使用的繩索
        }

        /// <summary>
        /// 尋找通往目標的第一條有效繩索
        /// </summary>
        /// <param name="startPos">玩家位置</param>
        /// <param name="targetPos">目標位置</param>
        /// <param name="ropes">所有可用繩索</param>
        /// <returns>建議的第一條繩索，若無路徑則返回 null</returns>
        public RopeData? FindNextRope(SdPointF startPos, SdPointF targetPos, List<RopeData> ropes)
        {
            // 1. 建立節點列表
            // 起點與終點
            var nodes = new List<GraphNode>();
            var startNode = new GraphNode { Position = startPos };
            var targetNode = new GraphNode { Position = targetPos };
            nodes.Add(startNode);
            nodes.Add(targetNode);

            // 繩索端點
            foreach (var rope in ropes)
            {
                nodes.Add(new GraphNode { Position = new SdPointF(rope.X, rope.TopY), AssociatedRope = rope, IsRopeTop = true });
                nodes.Add(new GraphNode { Position = new SdPointF(rope.X, rope.BottomY), AssociatedRope = rope, IsRopeTop = false });
            }

            // 2. BFS 搜尋
            var queue = new Queue<GraphNode>();
            var visited = new HashSet<GraphNode>();
            
            queue.Enqueue(startNode);
            visited.Add(startNode);

            while (queue.Count > 0)
            {
                var current = queue.Dequeue();

                // 檢查是否能到達目標 (判斷是否在同一層)
                if (CanWalk(current.Position, targetNode.Position))
                {
                    // 找到路徑！回溯找出第一條使用的繩索
                    return TraceBackFirstRope(current);
                }

                // 尋展鄰居
                foreach (var neighbor in nodes)
                {
                    if (visited.Contains(neighbor)) continue;

                    // 兩種移動方式：
                    // A. 行走 (Walking): 在同一層樓 (Y 接近)
                    // B. 爬繩 (Climbing): 同一條繩索的頂端<->底端

                    bool connected = false;
                    RopeData? traversingRope = null;

                    // 檢查是否是同一條繩索的另一端
                    if (current.AssociatedRope != null && neighbor.AssociatedRope != null &&
                        current.AssociatedRope == neighbor.AssociatedRope)
                    {
                        // 是同一條繩索的兩端 -> 可爬行
                        connected = true;
                        traversingRope = current.AssociatedRope;
                    }
                    // 檢查是否可水平行走 (同一層)
                    else if (CanWalk(current.Position, neighbor.Position))
                    {
                        connected = true;
                    }

                    if (connected)
                    {
                        neighbor.Parent = current;
                        neighbor.UsedRope = traversingRope; // 標記到達此節點是用爬繩
                        visited.Add(neighbor);
                        queue.Enqueue(neighbor);
                    }
                }
            }

            return null; // 找不到路徑
        }

        /// <summary>
        /// 判斷兩點是否可水平行走到達 (同一層樓)
        /// </summary>
        private bool CanWalk(SdPointF a, SdPointF b)
        {
            // 垂直高度差在容許範圍內 (例如 50px)
            // 注意：這裡假設無牆壁阻擋，或是簡單的平台遊戲
            // 在 Maplestory 中，通常同一層是指 Y 軸相近
            float yDiff = Math.Abs(a.Y - b.Y);
            
            // 允許較大的 Y 誤差，因為只有繩索能大幅改變 Y
            // 但不能太大以免跨層
            // 繩索通常長度 > 100，所以 50 是個合理的行走判定閾值
            return yDiff < 50.0f;
        }

        /// <summary>
        /// 回溯路徑，找出「第一條」被使用的繩索
        /// </summary>
        private RopeData? TraceBackFirstRope(GraphNode endNode)
        {
            var path = new List<GraphNode>();
            var curr = endNode;
            while (curr != null)
            {
                path.Add(curr);
                curr = curr.Parent;
            }
            path.Reverse();

            // path[0] 是起點
            // 尋找路徑中第一個 UsedRope 不為空的節點
            foreach (var node in path)
            {
                if (node.UsedRope != null)
                {
                    return node.UsedRope;
                }
            }
            return null;
        }
    }
}
===
using System;
using System.Collections.Generic;
using System.Linq;
using System.Drawing;
using ArtaleAI.Models.PathPlanning;
using ArtaleAI.Utils;
using SdPointF = System.Drawing.PointF;

namespace ArtaleAI.Services
{
    /// <summary>
    /// 智慧繩索導航器
    /// 使用圖搜尋算法 (BFS) 尋找跨樓層的繩索路徑
    /// ⚠️ 此類別在 Edge-Driven 架構下已被 PathPlanningTracker.InjectRopeEdges() 取代。
    /// A* 會自動規劃含繩索的完整路徑，不再需要獨立的 BFS 繩索搜尋。
    /// 僅保留供舊版循序導航模式使用。
    /// </summary>
    [System.Obsolete("Edge-Driven 模式下請使用 InjectRopeEdges() + A*，此類僅供舊版循序導航模式。")]
    public class SmartRopeNavigator
    {
        private class GraphNode
        {
            public SdPointF Position { get; set; }
            public RopeData? AssociatedRope { get; set; } // 如果是繩索端點，關聯的繩索
            public bool IsRopeTop { get; set; } // 是繩索頂端還是底端
            public GraphNode? Parent { get; set; } // 用於回溯路徑
            public RopeData? UsedRope { get; set; } // 到達此節點所使用的繩索
        }

        /// <summary>
        /// 尋找通往目標的第一條有效繩索
        /// </summary>
        /// <param name="startPos">玩家位置</param>
        /// <param name="targetPos">目標位置</param>
        /// <param name="ropes">所有可用繩索</param>
        /// <returns>建議的第一條繩索，若無路徑則返回 null</returns>
        public RopeData? FindNextRope(SdPointF startPos, SdPointF targetPos, List<RopeData> ropes)
        {
            // 1. 建立節點列表
            // 起點與終點
            var nodes = new List<GraphNode>();
            var startNode = new GraphNode { Position = startPos };
            var targetNode = new GraphNode { Position = targetPos };
            nodes.Add(startNode);
            nodes.Add(targetNode);

            // 繩索端點
            foreach (var rope in ropes)
            {
                nodes.Add(new GraphNode { Position = new SdPointF(rope.X, rope.TopY), AssociatedRope = rope, IsRopeTop = true });
                nodes.Add(new GraphNode { Position = new SdPointF(rope.X, rope.BottomY), AssociatedRope = rope, IsRopeTop = false });
            }

            // 2. BFS 搜尋
            var queue = new Queue<GraphNode>();
            var visited = new HashSet<GraphNode>();
            
            queue.Enqueue(startNode);
            visited.Add(startNode);

            while (queue.Count > 0)
            {
                var current = queue.Dequeue();

                // 檢查是否能到達目標 (判斷是否在同一層)
                if (CanWalk(current.Position, targetNode.Position))
                {
                    // 找到路徑！回溯找出第一條使用的繩索
                    return TraceBackFirstRope(current);
                }

                // 尋展鄰居
                foreach (var neighbor in nodes)
                {
                    if (visited.Contains(neighbor)) continue;

                    // 兩種移動方式：
                    // A. 行走 (Walking): 在同一層樓 (Y 接近)
                    // B. 爬繩 (Climbing): 同一條繩索的頂端<->底端

                    bool connected = false;
                    RopeData? traversingRope = null;

                    // 檢查是否是同一條繩索的另一端
                    if (current.AssociatedRope != null && neighbor.AssociatedRope != null &&
                        current.AssociatedRope == neighbor.AssociatedRope)
                    {
                        // 是同一條繩索的兩端 -> 可爬行
                        connected = true;
                        traversingRope = current.AssociatedRope;
                    }
                    // 檢查是否可水平行走 (同一層)
                    else if (CanWalk(current.Position, neighbor.Position))
                    {
                        connected = true;
                    }

                    if (connected)
                    {
                        neighbor.Parent = current;
                        neighbor.UsedRope = traversingRope; // 標記到達此節點是用爬繩
                        visited.Add(neighbor);
                        queue.Enqueue(neighbor);
                    }
                }
            }

            return null; // 找不到路徑
        }

        /// <summary>
        /// 判斷兩點是否可水平行走到達 (同一層樓)
        /// </summary>
        private bool CanWalk(SdPointF a, SdPointF b)
        {
            // 垂直高度差在容許範圍內 (例如 50px)
            // 注意：這裡假設無牆壁阻擋，或是簡單的平台遊戲
            // 在 Maplestory 中，通常同一層是指 Y 軸相近
            float yDiff = Math.Abs(a.Y - b.Y);
            
            // 允許較大的 Y 誤差，因為只有繩索能大幅改變 Y
            // 但不能太大以免跨層
            // 繩索通常長度 > 100，所以 50 是個合理的行走判定閾值
            return yDiff < 50.0f;
        }

        /// <summary>
        /// 回溯路徑，找出「第一條」被使用的繩索
        /// </summary>
        private RopeData? TraceBackFirstRope(GraphNode endNode)
        {
            var path = new List<GraphNode>();
            var curr = endNode;
            while (curr != null)
            {
                path.Add(curr);
                curr = curr.Parent;
            }
            path.Reverse();

            // path[0] 是起點
            // 尋找路徑中第一個 UsedRope 不為空的節點
            foreach (var node in path)
            {
                if (node.UsedRope != null)
                {
                    return node.UsedRope;
                }
            }
            return null;
        }
    }
}
