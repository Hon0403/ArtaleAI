### 問題四：消除 Magic Number ✅

`PathNode.GetPriority()` 中的 `50` 硬編碼已提取為具名常數 `VerticalPenaltyThreshold`。

```diff:PathNode.cs
using System;
using System.Collections.Generic;
using SdPointF = System.Drawing.PointF;

namespace ArtaleAI.Core
{
    /// <summary>
    /// 路徑動作類型
    /// </summary>
    public enum PathActionType
    {
        Idle,       // 無動作
        MoveLeft,   // 向左移動
        MoveRight,  // 向右移動
        ClimbUp,    // 爬繩上
        ClimbDown,  // 爬繩下
        JumpDown,   // 下跳平台
        Jump,       // 跳躍
        LeftJump,   // 左跳
        RightJump   // 右跳
    }
    
    /// <summary>
    /// 路徑節點類別 - 包含按鍵資訊、優先級計算、失敗追蹤和黑名單邏輯
    /// </summary>
    public class PathNode
    {
        /// <summary>
        /// 節點位置
        /// </summary>
        public SdPointF Position { get; set; }
        
        /// <summary>
        /// 節點在原始路徑中的索引
        /// </summary>
        public int Index { get; set; }
        
        /// <summary>
        /// 錄製時按下的按鍵列表（如 ["left", "alt"]）
        /// </summary>
        public List<string> Keys { get; set; } = new List<string>();
        
        /// <summary>
        /// 從按鍵推導的動作類型
        /// </summary>
        public PathActionType Action => DetermineAction();
        
        /// <summary>
        /// 最後訪問時間
        /// </summary>
        public DateTime LastVisitTime { get; set; } = DateTime.MinValue;
        
        /// <summary>
        /// 嘗試到達失敗的次數
        /// </summary>
        public int FailedAttempts { get; set; } = 0;
        
        /// <summary>
        /// 是否被加入黑名單（失敗次數 >= 3）
        /// </summary>
        public bool IsBlacklisted => FailedAttempts >= 3;

        /// <summary>
        /// 是否為路徑分段點 (Break)
        /// </summary>
        public bool IsBreak { get; set; } = false;
        
        /// <summary>
        /// 從按鍵列表推導動作類型
        /// </summary>
        private PathActionType DetermineAction()
        {
            bool hasLeft = Keys.Contains("left");
            bool hasRight = Keys.Contains("right");
            bool hasUp = Keys.Contains("up");
            bool hasDown = Keys.Contains("down");
            bool hasAlt = Keys.Contains("alt");
            
            // 組合鍵判斷
            if (hasAlt)
            {
                if (hasDown) return PathActionType.JumpDown;
                if (hasLeft) return PathActionType.LeftJump;
                if (hasRight) return PathActionType.RightJump;
                return PathActionType.Jump;
            }
            
            // 單鍵判斷
            if (hasUp) return PathActionType.ClimbUp;
            if (hasDown) return PathActionType.ClimbDown;
            if (hasLeft) return PathActionType.MoveLeft;
            if (hasRight) return PathActionType.MoveRight;
            
            return PathActionType.Idle;
        }
        
        /// <summary>
        /// 重置節點狀態（清除失敗計數和訪問時間）
        /// </summary>
        public void Reset()
        {
            FailedAttempts = 0;
            LastVisitTime = DateTime.MinValue;
        }
        
        /// <summary>
        /// 標記為成功到達
        /// </summary>
        public void MarkVisited()
        {
            LastVisitTime = DateTime.UtcNow;
            FailedAttempts = 0;
        }
        
        /// <summary>
        /// 標記為到達失敗
        /// </summary>
        public void MarkFailed()
        {
            FailedAttempts++;
        }
        
        /// <summary>
        /// 計算節點的選擇優先級
        /// 優先級越高，越容易被選中
        /// </summary>
        /// <param name="currentPos">當前玩家位置</param>
        /// <param name="now">當前時間</param>
        /// <returns>優先級分數</returns>
        public float GetPriority(SdPointF currentPos, DateTime now)
        {
            // 如果被加入黑名單，優先級為 0
            if (IsBlacklisted)
                return 0f;
            
            float distance = (float)Math.Sqrt(
                Math.Pow(Position.X - currentPos.X, 2) + 
                Math.Pow(Position.Y - currentPos.Y, 2)
            );
            
            // 🔧 修正1: 最小距離門檻（太近的點直接跳過，減少來回抖動）
            const float MinDistance = 15f;
            if (distance < MinDistance)
                return 0.01f;  // 幾乎不會被選中
            
            float priority = 1.0f;
            
            // 🔧 修正2: 距離權重 (修改為：越近越好)
            // 原本邏輯會導致跳過中間點直接選遠處的點
            // 新邏輯：距離越近，分數越高 (反比關係)
            priority *= 1000f / (distance + 50f);

            // 🔧 修正2.1: 垂直距離懲罰 (防止跨樓層選點)
            // 如果目標點垂直差距過大 (超過 50px)，大幅降低優先級
            // 這能確保角色先走完同樓層的點，再去爬繩
            if (Math.Abs(Position.Y - currentPos.Y) > 50)
            {
                priority *= 0.05f; // 極低優先級
            }
            
            // 🔧 修正3: 訪問時間（縮短冷卻從3分鐘改為30秒）
            if (LastVisitTime == DateTime.MinValue)
            {
                priority *= 2.5f;  // 從未訪問，高優先級
            }
            else
            {
                var secondsSinceVisit = (now - LastVisitTime).TotalSeconds;
                if (secondsSinceVisit < 30)
                    priority *= 0.1f;  // 30秒內訪問過，大幅降低優先級
                else if (secondsSinceVisit < 60)
                    priority *= 0.5f;  // 30-60秒，中等降低
                else if (secondsSinceVisit < 120)
                    priority *= 1.0f;  // 1-2分鐘，正常優先級
                else
                    priority *= 1.5f;  // 超過2分鐘，提高優先級
            }
            
            // 權重 3: 失敗懲罰
            if (FailedAttempts > 0)
                priority *= 0.3f / FailedAttempts;  // 每次失敗更嚴重懲罰
            
            // 確保優先級至少為 0.01（避免完全不被選中）
            return Math.Max(priority, 0.01f);
        }
        
        public override string ToString()
        {
            var keysStr = Keys.Count > 0 ? string.Join(",", Keys) : "none";
            return $"PathNode[{Index}] Pos=({Position.X:F1},{Position.Y:F1}) Action={Action} Keys=[{keysStr}] Failed={FailedAttempts}";
        }
    }
}

===
using System;
using System.Collections.Generic;
using SdPointF = System.Drawing.PointF;

namespace ArtaleAI.Core
{
    /// <summary>
    /// 路徑動作類型
    /// </summary>
    public enum PathActionType
    {
        Idle,       // 無動作
        MoveLeft,   // 向左移動
        MoveRight,  // 向右移動
        ClimbUp,    // 爬繩上
        ClimbDown,  // 爬繩下
        JumpDown,   // 下跳平台
        Jump,       // 跳躍
        LeftJump,   // 左跳
        RightJump   // 右跳
    }
    
    /// <summary>
    /// 路徑節點類別 - 包含按鍵資訊、優先級計算、失敗追蹤和黑名單邏輯
    /// </summary>
    public class PathNode
    {
        /// <summary>
        /// 節點位置
        /// </summary>
        public SdPointF Position { get; set; }
        
        /// <summary>
        /// 節點在原始路徑中的索引
        /// </summary>
        public int Index { get; set; }
        
        /// <summary>
        /// 錄製時按下的按鍵列表（如 ["left", "alt"]）
        /// </summary>
        public List<string> Keys { get; set; } = new List<string>();
        
        /// <summary>
        /// 從按鍵推導的動作類型
        /// </summary>
        public PathActionType Action => DetermineAction();
        
        /// <summary>
        /// 最後訪問時間
        /// </summary>
        public DateTime LastVisitTime { get; set; } = DateTime.MinValue;
        
        /// <summary>
        /// 嘗試到達失敗的次數
        /// </summary>
        public int FailedAttempts { get; set; } = 0;
        
        /// <summary>
        /// 是否被加入黑名單（失敗次數 >= 3）
        /// </summary>
        public bool IsBlacklisted => FailedAttempts >= 3;

        /// <summary>
        /// 是否為路徑分段點 (Break)
        /// </summary>
        public bool IsBreak { get; set; } = false;
        
        /// <summary>
        /// 從按鍵列表推導動作類型
        /// </summary>
        private PathActionType DetermineAction()
        {
            bool hasLeft = Keys.Contains("left");
            bool hasRight = Keys.Contains("right");
            bool hasUp = Keys.Contains("up");
            bool hasDown = Keys.Contains("down");
            bool hasAlt = Keys.Contains("alt");
            
            // 組合鍵判斷
            if (hasAlt)
            {
                if (hasDown) return PathActionType.JumpDown;
                if (hasLeft) return PathActionType.LeftJump;
                if (hasRight) return PathActionType.RightJump;
                return PathActionType.Jump;
            }
            
            // 單鍵判斷
            if (hasUp) return PathActionType.ClimbUp;
            if (hasDown) return PathActionType.ClimbDown;
            if (hasLeft) return PathActionType.MoveLeft;
            if (hasRight) return PathActionType.MoveRight;
            
            return PathActionType.Idle;
        }
        
        /// <summary>
        /// 重置節點狀態（清除失敗計數和訪問時間）
        /// </summary>
        public void Reset()
        {
            FailedAttempts = 0;
            LastVisitTime = DateTime.MinValue;
        }
        
        /// <summary>
        /// 標記為成功到達
        /// </summary>
        public void MarkVisited()
        {
            LastVisitTime = DateTime.UtcNow;
            FailedAttempts = 0;
        }
        
        /// <summary>
        /// 標記為到達失敗
        /// </summary>
        public void MarkFailed()
        {
            FailedAttempts++;
        }
        
        /// <summary>
        /// 計算節點的選擇優先級
        /// 優先級越高，越容易被選中
        /// </summary>
        /// <param name="currentPos">當前玩家位置</param>
        /// <param name="now">當前時間</param>
        /// <returns>優先級分數</returns>
        public float GetPriority(SdPointF currentPos, DateTime now)
        {
            // 如果被加入黑名單，優先級為 0
            if (IsBlacklisted)
                return 0f;
            
            float distance = (float)Math.Sqrt(
                Math.Pow(Position.X - currentPos.X, 2) + 
                Math.Pow(Position.Y - currentPos.Y, 2)
            );
            
            // 🔧 修正1: 最小距離門檻（太近的點直接跳過，減少來回抖動）
            const float MinDistance = 15f;
            if (distance < MinDistance)
                return 0.01f;  // 幾乎不會被選中
            
            float priority = 1.0f;
            
            // 🔧 修正2: 距離權重 (修改為：越近越好)
            // 原本邏輯會導致跳過中間點直接選遠處的點
            // 新邏輯：距離越近，分數越高 (反比關係)
            priority *= 1000f / (distance + 50f);

            // 🔧 修正2.1: 垂直距離懲罰 (防止跨樓層選點)
            // 如果目標點垂直差距過大，大幅降低優先級
            // 這能確保角色先走完同樓層的點，再去爬繩
            // ⚠️ 此閾值為小地圖座標，不同地圖的繩索長度不同，可能需要調整
            const float VerticalPenaltyThreshold = 50f;
            if (Math.Abs(Position.Y - currentPos.Y) > VerticalPenaltyThreshold)
            {
                priority *= 0.05f; // 極低優先級
            }
            
            // 🔧 修正3: 訪問時間（縮短冷卻從3分鐘改為30秒）
            if (LastVisitTime == DateTime.MinValue)
            {
                priority *= 2.5f;  // 從未訪問，高優先級
            }
            else
            {
                var secondsSinceVisit = (now - LastVisitTime).TotalSeconds;
                if (secondsSinceVisit < 30)
                    priority *= 0.1f;  // 30秒內訪問過，大幅降低優先級
                else if (secondsSinceVisit < 60)
                    priority *= 0.5f;  // 30-60秒，中等降低
                else if (secondsSinceVisit < 120)
                    priority *= 1.0f;  // 1-2分鐘，正常優先級
                else
                    priority *= 1.5f;  // 超過2分鐘，提高優先級
            }
            
            // 權重 3: 失敗懲罰
            if (FailedAttempts > 0)
                priority *= 0.3f / FailedAttempts;  // 每次失敗更嚴重懲罰
            
            // 確保優先級至少為 0.01（避免完全不被選中）
            return Math.Max(priority, 0.01f);
        }
        
        public override string ToString()
        {
            var keysStr = Keys.Count > 0 ? string.Join(",", Keys) : "none";
            return $"PathNode[{Index}] Pos=({Position.X:F1},{Position.Y:F1}) Action={Action} Keys=[{keysStr}] Failed={FailedAttempts}";
        }
    }
}

```

