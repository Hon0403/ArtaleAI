## Phase 1：更新 MapData DTO（新 JSON 格式）

新增直接儲存導航圖的屬性 [Nodes](file:///d:/Full_end/C%23/ArtaleAI/Core/Domain/Navigation/NavigationGraph.cs#120-121) 與 [Edges](file:///d:/Full_end/C%23/ArtaleAI/Core/PathPlanningTracker.cs#274-342)。
> ⚠️ **保留 `WaypointPaths` 與 `Connections`** 供舊檔反序列化以及 MapEditor 內部暫存使用。

```csharp
public class MapData
{
    // ===== 核心導航資料 (Route B) =====
    /// <summary>導航節點列表</summary>
    public List<NavNodeData> Nodes { get; set; } = new();
    
    /// <summary>導航邊列表</summary>
    public List<NavEdgeData> Edges { get; set; } = new();

    // ===== 舊檔反序列化 / MapEditor 內部狀態 =====
    public List<float[]> WaypointPaths { get; set; } = new();
    public List<int[]> Connections { get; set; } = new();

    // ===== 附加環境資料 =====
    public List<float[]> SafeZones { get; set; } = new();
    public List<float[]> Ropes { get; set; } = new();
    public List<float[]> BoundaryMarkers { get; set; } = new();
}
// NavNodeData 與 NavEdgeData 相同...
```

/// <summary>節點序列化 DTO</summary>
public class NavNodeData
{
    public string Id { get; set; } = "";
    public float X { get; set; }
    public float Y { get; set; }
    public string Type { get; set; } = "Platform"; // Platform, Rope
}

/// <summary>邊序列化 DTO</summary>
public class NavEdgeData
{
    public string From { get; set; } = "";
    public string To { get; set; } = "";
    public string Action { get; set; } = "Walk"; // Walk, JumpLeft, JumpRight, ClimbUp, ClimbDown
    public float Cost { get; set; } = 1.0f;
    public List<string>? InputSequence { get; set; }
}
```

