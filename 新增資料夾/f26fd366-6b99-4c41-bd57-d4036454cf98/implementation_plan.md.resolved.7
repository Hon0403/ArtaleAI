private async void ProcessPathPlanning(PathPlanningState pathState)
{
    // ... 現有邏輯 ...
    
    // 檢查是否需要爬繩
    var rope = _pathPlanningManager.Tracker.FindNearbyRope(playerPos, targetPos);
    if (rope != null)
    {
        Logger.Info($"[路徑規劃] 偵測到需要爬繩，繩索位置 X={rope.X}");
        
        await _movementController.ClimbRopeAsync(
            playerPos,
            rope.X,
            targetPos.Y,
            () => GetCurrentPlayerPosition(),
            _pathPlanningCts.Token);
        
        return;  // 爬繩後跳過本次移動
    }
    
    // ... 正常移動邏輯 ...
}
