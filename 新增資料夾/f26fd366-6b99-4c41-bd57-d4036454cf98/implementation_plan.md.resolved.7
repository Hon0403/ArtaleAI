### 1. [CharacterMovementController.cs](file:///d:/Full_end/C%23/ArtaleAI/Services/CharacterMovementController.cs) (新增方法)

```csharp
// 新增常數
private const ushort VK_MENU = 0x12;  // Alt 鍵

/// <summary>
/// 爬繩索到指定 Y 座標
/// </summary>
public async Task ClimbRopeAsync(
    PointF playerPos, 
    float ropeX, 
    float targetY,
    Func<PointF> getPlayerPosition,
    CancellationToken ct = default)
{
    float dx = ropeX - playerPos.X;
    
    // 1. 判斷繩索方向
    ushort directionKey = 0;
    if (dx > 3)
    {
        directionKey = VK_RIGHT;
        Logger.Info($"[爬繩] 繩索在右邊 (dx={dx:F1}px)");
    }
    else if (dx < -3)
    {
        directionKey = VK_LEFT;
        Logger.Info($"[爬繩] 繩索在左邊 (dx={dx:F1}px)");
    }
    else
    {
        Logger.Info($"[爬繩] 繩索在正下方");
    }
    
    // 2. 執行跳躍抓繩組合鍵
    //    Step 1: 按住方向鍵
    if (directionKey != 0)
    {
        SendKeyInput(directionKey, false);  // 按下
        await Task.Delay(30, ct);
    }
    
    //    Step 2: 點按 Alt + ↑
    SendKeyInput(VK_MENU, false);   // 按下 Alt
    SendKeyInput(VK_UP, false);     // 按下 ↑
    await Task.Delay(50, ct);
    
    //    Step 3: 放開方向鍵和 Alt
    if (directionKey != 0)
        SendKeyInput(directionKey, true);  // 放開
    SendKeyInput(VK_MENU, true);    // 放開 Alt
    
    // 3. 持續按住 ↑ 爬繩
    Logger.Info($"[爬繩] 開始爬繩，目標 Y={targetY:F1}");
    
    int maxAttempts = 100;  // 防止無限循環
    int attempts = 0;
    
    while (attempts++ < maxAttempts && !ct.IsCancellationRequested)
    {
        var currentPos = getPlayerPosition();
        
        // 檢查是否到達目標
        if (Math.Abs(currentPos.Y - targetY) < 5)
        {
            Logger.Info($"[爬繩] ✅ 已到達 Y={currentPos.Y:F1}");
            break;
        }
        
        // 確保 ↑ 鍵持續按住
        SendKeyInput(VK_UP, false);
        await Task.Delay(50, ct);
    }
    
    // 4. 放開 ↑
    SendKeyInput(VK_UP, true);
    Logger.Info("[爬繩] 爬繩完成");
}
```

### 2. [PathPlanningTracker.cs](file:///d:/Full_end/C%23/ArtaleAI/Core/PathPlanningTracker.cs) (新增繩索處理)

```csharp
private List<RopeData> _ropes = new();

public void SetRopes(List<float[]> ropes)
{
    _ropes = ropes.Select(r => new RopeData
    {
        X = r[0],
        TopY = r.Length > 1 ? r[1] : 0,
        BottomY = r.Length > 2 ? r[2] : 999
    }).ToList();
    
    Logger.Info($"[路徑追蹤] 設定 {_ropes.Count} 條繩索");
}

public RopeData? FindNearbyRope(PointF playerPos, PointF targetPos)
{
    // 只有當需要往上移動時才搜尋繩索
    if (targetPos.Y >= playerPos.Y - 5)
        return null;
    
    // 搜尋在玩家和目標之間的繩索
    float minX = Math.Min(playerPos.X, targetPos.X) - 15;
    float maxX = Math.Max(playerPos.X, targetPos.X) + 15;
    
    return _ropes.FirstOrDefault(r =>
        r.X >= minX && r.X <= maxX &&
        r.TopY <= targetPos.Y + 10 &&
        r.BottomY >= playerPos.Y - 10);
}

public class RopeData
{
    public float X { get; set; }
    public float TopY { get; set; }
    public float BottomY { get; set; }
}
```

