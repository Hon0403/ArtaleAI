    private List<PointF> _ropePositions;
    
    public bool IsNearRope(PointF playerPos, out PointF? ropePos)
    {
        foreach (var rope in _ropePositions)
        {
            if (Math.Abs(playerPos.X - rope.X) < 5 && 
                playerPos.Y >= rope.Y - 30)
            {
                ropePos = rope;
                return true;
