}
```

#### 修改 [PathPlanningTracker.cs](file:///d:/Full_end/C%23/ArtaleAI/Core/PathPlanningTracker.cs)
```csharp
// 當到達路徑點時，檢查是否有動作要執行
private void OnWaypointReached(SdPoint waypoint, int waypointIndex)
{
    var path = CurrentPathState.PlannedPath;
    if (waypointIndex < path.Count)
    {
        var waypointData = _mapData.WaypointPaths[waypointIndex];
        if (waypointData.Length >= 3)
        {
            var actionCode = (int)waypointData[2];
            if (actionCode > 0)
            {
                OnActionRequired?.Invoke((MovementAction)actionCode);
            }
        }
    }
}
```

