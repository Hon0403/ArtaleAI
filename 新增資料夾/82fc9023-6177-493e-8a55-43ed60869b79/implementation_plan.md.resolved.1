### PathPlanningTracker.cs - 新增安全選點方法

```diff
+ private int SelectSafeRandomTarget(int currentIndex)
+ {
+     var availableIndices = Enumerable.Range(0, CurrentPathState.PlannedPath.Count)
+         .Where(i => i != currentIndex)
+         .Where(i => {
+             if (_platformBounds == null) return true;
+             var point = CurrentPathState.PlannedPath[i];
+             var bufferZone = AppConfig.Instance.PlatformBounds.BufferZone;
+             return !_platformBounds.IsNearBoundary(point.X, point.Y, bufferZone);
+         })
+         .ToList();
+
+     if (availableIndices.Count == 0)
+     {
+         // 找不到安全點，使用所有可用點
+         availableIndices = Enumerable.Range(0, CurrentPathState.PlannedPath.Count)
+             .Where(i => i != currentIndex)
+             .ToList();
+     }
+
+     lock (_randomLock)
+     {
+         return availableIndices[_random.Next(availableIndices.Count)];
+     }
+ }
```

